---
export const prerender = false;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Panel de Administración - Glosario</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Special+Elite&display=swap" rel="stylesheet">
    <style>
      :root {
        --paper-color: #fefcf6;
        --paper-line: #e8e4d9;
        --ink-color: #2c241b;
        --accent-color: #8b4513;
      }
      
      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      body {
        font-family: 'Special Elite', cursive;
        color: var(--ink-color);
        background: linear-gradient(135deg, #f5f2e8 0%, #ebe7db 100%);
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>