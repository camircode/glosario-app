---
import AdminLayout from '../../layouts/AdminLayout.astro';
  import { getTerms } from '../../lib/api';
  import { createTerm, updateTerm, deleteTerm } from '../../lib/api-client';
import { BookOpen, Plus, LogOut, Trash2, Edit, ExternalLink } from 'lucide-react';

export const prerender = false;

let terms = [];
let error = null;

try {
  terms = await getTerms();
} catch (err) {
  error = 'Error al cargar los términos';
}
---

<AdminLayout>
  <div class="min-h-screen">
    <nav class="bg-white/10 backdrop-blur-lg border-b border-white/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-500 rounded-xl flex items-center justify-center shadow-lg">
              <BookOpen className="w-5 h-5 text-white" />
            </div>
            <span class="font-semibold text-white text-lg">Panel Admin</span>
          </div>
          
          <div class="flex items-center gap-4">
            <a
              href="/"
              target="_blank"
              class="flex items-center gap-2 px-4 py-2 text-indigo-200 hover:text-white transition-colors"
            >
              <ExternalLink className="w-4 h-4" />
              <span class="text-sm">Ver Glosario</span>
            </a>
            
            <button
              id="logoutBtn"
              class="flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-xl transition-all"
            >
              <LogOut className="w-4 h-4" />
              <span class="text-sm">Cerrar sesión</span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold text-white mb-2">Gestión de Términos</h1>
          <p class="text-indigo-200">{terms.length} términos en el glosario</p>
        </div>
        
        <button
          id="addTermBtn"
          class="flex items-center gap-2 px-6 py-3 bg-indigo-500 hover:bg-indigo-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all"
        >
          <Plus className="w-5 h-5" />
          <span>Nuevo Término</span>
        </button>
      </div>

      {error && (
        <div class="p-4 bg-red-500/20 border border-red-500/30 rounded-xl text-red-200 mb-6">
          {error}
        </div>
      )}

      <div class="bg-white/10 backdrop-blur-lg rounded-2xl border border-white/20 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-white/5 border-b border-white/10">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-medium text-indigo-200 uppercase tracking-wider">Término</th>
                <th class="px-6 py-4 text-left text-xs font-medium text-indigo-200 uppercase tracking-wider">Definición</th>
                <th class="px-6 py-4 text-left text-xs font-medium text-indigo-200 uppercase tracking-wider">Imagen</th>
                <th class="px-6 py-4 text-right text-xs font-medium text-indigo-200 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              {terms.map((term) => (
                <tr key={term.id} class="hover:bg-white/5 transition-colors">
                  <td class="px-6 py-4">
                    <div class="font-medium text-white">{term.name}</div>
                  </td>
                  <td class="px-6 py-4">
                    <div class="text-indigo-200 text-sm max-w-md truncate">
                      {term.definition}
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    {term.imageUrl ? (
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">
                        Sí
                      </span>
                    ) : (
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-500/20 text-gray-400">
                        No
                      </span>
                    )}
                  </td>
                  <td class="px-6 py-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <button
                        class="edit-btn p-2 text-indigo-300 hover:text-white hover:bg-white/10 rounded-lg transition-all"
                        data-id={term.id}
                        data-name={term.name}
                        data-definition={term.definition}
                        data-image={term.imageUrl || ''}
                      >
                        <Edit className="w-4 h-4" />
                      </button>
                      <button
                        class="delete-btn p-2 text-red-300 hover:text-red-200 hover:bg-red-500/20 rounded-lg transition-all"
                        data-id={term.id}
                        data-name={term.name}
                      >
                        <Trash2 className="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        
        {terms.length === 0 && (
          <div class="p-12 text-center">
            <BookOpen className="w-16 h-16 mx-auto mb-4 text-indigo-300/50" />
            <p class="text-indigo-200 text-lg mb-2">No hay términos aún</p>
            <p class="text-indigo-300/60 text-sm">Haz clic en "Nuevo Término" para agregar uno</p>
          </div>
        )}
      </div>
    </main>
  </div>

  <div id="termModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4 z-50">
    <div class="bg-[#1e1b4b] rounded-2xl p-8 max-w-lg w-full max-h-[90vh] overflow-y-auto shadow-2xl border border-white/20">
      <h2 id="modalTitle" class="text-2xl font-bold text-white mb-6">Nuevo Término</h2>
      
      <form id="termForm" class="space-y-6">
        <input type="hidden" id="termId" />
        
        <div>
          <label for="termName" class="block text-sm font-medium text-indigo-200 mb-2">
            Nombre del término *
          </label>
          <input
            type="text"
            id="termName"
            required
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400"
            placeholder="Ej: Algoritmo"
          />
        </div>

        <div>
          <label for="termDefinition" class="block text-sm font-medium text-indigo-200 mb-2">
            Definición *
          </label>
          <textarea
            id="termDefinition"
            required
            rows="4"
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 resize-none"
            placeholder="Escribe la definición del término..."
          ></textarea>
        </div>

        <div>
          <label for="termImageUrl" class="block text-sm font-medium text-indigo-200 mb-2">
            URL de la imagen
          </label>
          <input
            type="url"
            id="termImageUrl"
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400"
            placeholder="https://ejemplo.com/imagen.jpg"
          />
          <p class="mt-1 text-xs text-indigo-400">Dejar vacío si no hay imagen</p>
        </div>

        <div id="formError" class="hidden p-3 bg-red-500/20 border border-red-500/30 rounded-xl text-red-200 text-sm"></div>

        <div class="flex gap-3 pt-4">
          <button
            type="button"
            id="cancelBtn"
            class="flex-1 px-4 py-3 bg-white/10 hover:bg-white/20 text-white rounded-xl transition-all"
          >
            Cancelar
          </button>
          <button
            type="submit"
            id="saveBtn"
            class="flex-1 px-4 py-3 bg-indigo-500 hover:bg-indigo-600 text-white font-semibold rounded-xl shadow-lg transition-all"
          >
            Guardar
          </button>
        </div>
      </form>
    </div>
  </div>

  <div id="deleteModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4 z-50">
    <div class="bg-[#1e1b4b] rounded-2xl p-8 max-w-md w-full shadow-2xl border border-white/20">
      <h2 class="text-2xl font-bold text-white mb-4">Eliminar Término</h2>
      
      <p class="text-indigo-200 mb-6">
        ¿Estás seguro de que deseas eliminar <span id="deleteTermName" class="font-semibold text-white"></span>?
        Esta acción no se puede deshacer.
      </p>

      <div class="flex gap-3">
        <button
          id="cancelDeleteBtn"
          class="flex-1 px-4 py-3 bg-white/10 hover:bg-white/20 text-white rounded-xl transition-all"
        >
          Cancelar
        </button>
        <button
          id="confirmDeleteBtn"
          class="flex-1 px-4 py-3 bg-red-500 hover:bg-red-600 text-white font-semibold rounded-xl shadow-lg transition-all"
        >
          Eliminar
        </button>
      </div>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    
    const termModal = document.getElementById('termModal');
    const deleteModal = document.getElementById('deleteModal');
    const termForm = document.getElementById('termForm');
    const modalTitle = document.getElementById('modalTitle');
    const formError = document.getElementById('formError');
    let deleteTermId = null;

    document.getElementById('addTermBtn').addEventListener('click', () => {
      modalTitle.textContent = 'Nuevo Término';
      termForm.reset();
      document.getElementById('termId').value = '';
      formError.classList.add('hidden');
      termModal.classList.remove('hidden');
      termModal.classList.add('flex');
    });

    document.getElementById('cancelBtn').addEventListener('click', () => {
      termModal.classList.add('hidden');
      termModal.classList.remove('flex');
    });

    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        modalTitle.textContent = 'Editar Término';
        document.getElementById('termId').value = btn.dataset.id;
        document.getElementById('termName').value = btn.dataset.name;
        document.getElementById('termDefinition').value = btn.dataset.definition;
        document.getElementById('termImageUrl').value = btn.dataset.image;
        formError.classList.add('hidden');
        termModal.classList.remove('hidden');
        termModal.classList.add('flex');
      });
    });

    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        deleteTermId = btn.dataset.id;
        document.getElementById('deleteTermName').textContent = btn.dataset.name;
        deleteModal.classList.remove('hidden');
        deleteModal.classList.add('flex');
      });
    });

    document.getElementById('cancelDeleteBtn').addEventListener('click', () => {
      deleteModal.classList.add('hidden');
      deleteModal.classList.remove('flex');
      deleteTermId = null;
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
      if (!deleteTermId) return;
      
      try {
        const response = await fetch(`${API_URL}/api/terms/${deleteTermId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        
        if (response.ok) {
          window.location.reload();
        } else {
          alert('Error al eliminar el término');
        }
      } catch (error) {
        alert('Error de conexión');
      }
    });

    termForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const id = document.getElementById('termId').value;
      const data = {
        name: document.getElementById('termName').value,
        definition: document.getElementById('termDefinition').value,
        imageUrl: document.getElementById('termImageUrl').value || null,
      };
      
      const saveBtn = document.getElementById('saveBtn');
      saveBtn.disabled = true;
      saveBtn.textContent = 'Guardando...';
      formError.classList.add('hidden');
      
      try {
        const url = id ? `${API_URL}/api/terms/${id}` : `${API_URL}/api/terms`;
        const method = id ? 'PUT' : 'POST';
        
        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(data),
        });
        
        if (response.ok) {
          window.location.reload();
        } else {
          const errorData = await response.json();
          formError.textContent = errorData.error || 'Error al guardar el término';
          formError.classList.remove('hidden');
        }
      } catch (error) {
        formError.textContent = 'Error de conexión';
        formError.classList.remove('hidden');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Guardar';
      }
    });

    document.getElementById('logoutBtn').addEventListener('click', async () => {
      try {
        await fetch(`${API_URL}/api/auth/sign-out`, {
          method: 'POST',
          credentials: 'include',
        });
      } catch (error) {
        console.error('Error logging out:', error);
      }
      window.location.href = '/admin';
    });
  </script>
</AdminLayout>