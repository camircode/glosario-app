---
import Layout from '../layouts/Layout.astro';
import NotebookCarousel from '../components/NotebookCarousel';
import { getTerms } from '../lib/api';
import { BookOpen, Shield } from 'lucide-react';

export const prerender = false;

let terms = [];
try {
  terms = await getTerms();
} catch (error) {
  console.error('Error fetching terms:', error);
}
---

<Layout>
  <div class="min-h-screen">
    <header class="relative py-8 px-4">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="p-3 bg-amber-800 rounded-lg shadow-lg">
            <BookOpen className="w-8 h-8 text-amber-100" />
          </div>
          <div>
            <h1 
              class="text-3xl font-bold text-amber-900"
              style="font-family: 'Caveat', cursive;"
            >
              Glosario de Informática
            </h1>
            <p class="text-amber-700/60 text-sm mt-1">
              Tu libreta de términos tecnológicos
            </p>
          </div>
        </div>
        
        <a
          href="/admin"
          class="flex items-center gap-2 px-4 py-2 bg-amber-800 text-amber-100 rounded-lg shadow-lg hover:bg-amber-900 hover:shadow-xl transition-all duration-200"
        >
          <Shield className="w-4 h-4" />
          <span class="text-sm font-medium">Admin</span>
        </a>
      </div>
    </header>

    <main class="pb-12">
      <NotebookCarousel terms={terms} client:load />
    </main>

    <footer class="py-6 text-center">
      <p class="text-sm text-amber-700/40">
        {terms.length} términos en el glosario
      </p>
    </footer>
  </div>
</Layout>