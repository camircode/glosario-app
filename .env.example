# Glosario App Environment Variables

# Database
DB_USER=glosario
DB_PASSWORD=change_this_password
DB_NAME=glosario

# Backend Configuration
BACKEND_URL=https://api.tu-dominio.com
BETTER_AUTH_SECRET=your-super-secret-key-min-32-characters-long
BETTER_AUTH_URL=https://api.tu-dominio.com

# Frontend Configuration
PUBLIC_API_URL=https://api.tu-dominio.com

# Admin Credentials
ADMIN_EMAIL=admin@tu-dominio.com
ADMIN_PASSWORD=change_this_password

# Traefik Router Names (optional, for custom routing)
BACKEND_ROUTER_NAME=glosario-backend
FRONTEND_ROUTER_NAME=glosario-frontend

# Internal network name (set by Dokploy)
NETWORK_NAME=traefik-web